{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A blog post entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "readTime": { "type": "string" }
      },
      "required": ["title", "content", "author", "authorId", "date"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
